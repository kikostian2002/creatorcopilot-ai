# ─────────────────────────────────────────────
# CreatorCopilot AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# CORS
CORS_ORIGIN=http://localhost:5173

# Database (MongoDB example — swap for your DB of choice)
DATABASE_URL=mongodb://localhost:27017/creatorcopilot

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# AI Provider (e.g. OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Logging
LOG_LEVEL=debug
